# ─────────────────────────────────────────────────────────────────────────────
# Production environment variable template
# Copy this file to .env.auth.local / .env.meetings.local / .env.users.local
# and fill in the values for each microservice.
#
# NEVER commit real credentials. Use AWS Secrets Manager or SSM Parameter
# Store in production, and inject values via your EC2 user-data / ECS task
# definition environment variables.
# ─────────────────────────────────────────────────────────────────────────────

# ── Node ─────────────────────────────────────────────────────────────────────
NODE_ENV=production

# ── Networking ───────────────────────────────────────────────────────────────
# The public-facing URL served by the ALB (used in emails / OAuth2 redirects)
PUBLIC_URL=https://your-alb-dns.amazonaws.com
# Set true when behind the ALB so X-Forwarded-For is trusted for rate limiting
TRUST_PROXY=true
# Enable CORS because the React app (Amplify) is on a different origin
ENABLE_CORS=true
# The Amplify app origin (e.g. https://main.xxxxxx.amplifyapp.com)
# Add additional origins separated by commas
EXTRA_CORS_ORIGINS=https://main.xxxxxx.amplifyapp.com

# Ports (one value per service container / EC2 instance)
# auth-service      → PORT=3001
# meetings-service  → PORT=3002
# users-service     → PORT=3003
PORT=3001
HOST=0.0.0.0

# ── AWS Cognito ───────────────────────────────────────────────────────────────
COGNITO_REGION=us-west-2
COGNITO_USER_POOL_ID=us-west-2_XXXXXXXXX
COGNITO_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Database (RDS MariaDB) ────────────────────────────────────────────────────
DATABASE_TYPE=mariadb
# RDS endpoint (from the AWS console under "Connectivity & security")
MYSQL_HOST=time2meet.xxxxxxxxxxxxxxxx.us-west-2.rds.amazonaws.com
MYSQL_PORT=3306
MYSQL_USER=time2meet
# Store the password in AWS Secrets Manager; reference it here for local-only use
MYSQL_PASSWORD=CHANGE_ME
MYSQL_DATABASE=time2meet

# ── Redis (ElastiCache – optional) ───────────────────────────────────────────
# If unset, an in-memory cache is used (not suitable for multi-instance deployments)
REDIS_HOST=time2meet.xxxxxx.0001.use1.cache.amazonaws.com
REDIS_PORT=6379

# ── Email (Amazon SES via SMTP) ───────────────────────────────────────────────
# Get SES SMTP credentials from the SES console → SMTP Settings → Create credentials
SMTP_HOST=email-smtp.us-west-2.amazonaws.com
SMTP_PORT=587
SMTP_FROM=noreply@yourdomain.com
SMTP_USER=AKIAIOSFODNN7EXAMPLE
SMTP_PASSWORD=CHANGE_ME
# Daily email limit (0 = no limit; SES sandbox = 200/day by default)
EMAIL_DAILY_LIMIT=200

# ── Auth behaviour ────────────────────────────────────────────────────────────
VERIFY_SIGNUP_EMAIL_ADDRESS=true

# ── Google OAuth2 (optional) ──────────────────────────────────────────────────
# OAUTH2_GOOGLE_CLIENT_ID=
# OAUTH2_GOOGLE_CLIENT_SECRET=
# OAUTH2_GOOGLE_REDIRECT_URI=https://your-alb-dns.amazonaws.com/redirect/google

# ── Microsoft OAuth2 (optional) ───────────────────────────────────────────────
# OAUTH2_MICROSOFT_CLIENT_ID=
# OAUTH2_MICROSOFT_REDIRECT_URI=https://your-alb-dns.amazonaws.com/redirect/microsoft
# OAUTH2_MICROSOFT_CERTIFICATE=
# OAUTH2_MICROSOFT_PRIVATE_KEY=
# OAUTH2_MICROSOFT_TENANT_ID=consumers

# ── Rate limiting ─────────────────────────────────────────────────────────────
HOURLY_MEETING_CREATION_LIMIT_PER_IP=100
DELETE_MEETINGS_OLDER_THAN_NUM_DAYS=60
